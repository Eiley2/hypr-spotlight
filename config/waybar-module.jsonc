{
  "custom/project": {
    "exec": "hypr-spotlight waybar",
    "return-type": "json",
    "interval": 1,
    "signal": 11,
    "on-click": "hypr-spotlight switch",
    "on-click-right": "hypr-spotlight create",
    "on-click-middle": "hypr-spotlight close",
    "on-scroll-up": "hypr-spotlight next",
    "on-scroll-down": "hypr-spotlight prev"
  }
}
