#!/bin/bash

MIN_SCREENS=3
BLOCK=10
STATE_DIR="$HOME/.cache/hypr-spotlight"
PROJECTS_FILE="$STATE_DIR/projects"
CURRENT_FILE="$STATE_DIR/current"
NAMES_FILE="$STATE_DIR/window-names"
SCREEN_NAMES_FILE="$STATE_DIR/screen-names"
ICONS_FILE="$STATE_DIR/project-icons"
USAGE_FILE="$STATE_DIR/usage.tsv"
APPS_CACHE="$STATE_DIR/apps-cache.tsv"
DEBUG_LOG="$STATE_DIR/debug.log"
PROJECT_MENU_FILE="$STATE_DIR/project-menu.xml"

mkdir -p "$STATE_DIR"
touch "$PROJECTS_FILE" "$NAMES_FILE" "$SCREEN_NAMES_FILE" "$ICONS_FILE" "$USAGE_FILE"

get_current() {
    cat "$CURRENT_FILE" 2>/dev/null
}

debug_log() {
    [ "${HYPR_SPOTLIGHT_DEBUG:-0}" = "1" ] || return 0
    printf '%s\tpid=%s\tcmd=%s\t%s\n' "$(date +%H:%M:%S.%3N)" "$$" "${1:-unknown}" "${2:-}" >> "$DEBUG_LOG"
}

set_current() {
    local value="$1"
    local tmp

    tmp=$(mktemp)
    printf '%s\n' "$value" > "$tmp"
    mv "$tmp" "$CURRENT_FILE"
    debug_log "set_current" "value=$value active_ws=$(active_workspace_id || printf '?')"
}

clear_current() {
    local tmp

    tmp=$(mktemp)
    : > "$tmp"
    mv "$tmp" "$CURRENT_FILE"
    debug_log "clear_current" "active_ws=$(active_workspace_id || printf '?')"
}

active_workspace_id() {
    local active_ws

    active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq -r '.id // empty' 2>/dev/null)
    case "$active_ws" in
        ''|null|*[!0-9-]*)
            return 1
            ;;
    esac
    [ "$active_ws" -lt 1 ] && return 1
    printf '%s\n' "$active_ws"
}

get_start() {
    local name="$1"
    while IFS=$'\t' read -r n s; do
        [ "$n" = "$name" ] && echo "$s" && return
    done < "$PROJECTS_FILE"
}

get_tsv_value() {
    local file="$1"
    local key="$2"
    [ -f "$file" ] || return 1
    awk -F'\t' -v key="$key" '$1 == key { print $2; exit }' "$file"
}

set_tsv_value() {
    local file="$1"
    local key="$2"
    local value="$3"
    local tmp

    tmp=$(mktemp)
    [ -f "$file" ] && awk -F'\t' -v key="$key" '$1 != key { print }' "$file" > "$tmp"
    printf '%s\t%s\n' "$key" "$value" >> "$tmp"
    mv "$tmp" "$file"
}

delete_tsv_key() {
    local file="$1"
    local key="$2"
    local tmp

    tmp=$(mktemp)
    [ -f "$file" ] && awk -F'\t' -v key="$key" '$1 != key { print }' "$file" > "$tmp"
    mv "$tmp" "$file"
}

increment_usage() {
    local key="$1"
    python3 - "$USAGE_FILE" "$key" <<'PY'
from pathlib import Path
import sys
import time

path = Path(sys.argv[1])
key = sys.argv[2]
rows = {}

if path.exists():
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        rows[parts[0]] = [int(parts[1]), int(parts[2])]

count, _stamp = rows.get(key, [0, 0])
rows[key] = [count + 1, int(time.time())]

with path.open("w") as handle:
    for row_key, (row_count, row_stamp) in rows.items():
        handle.write(f"{row_key}\t{row_count}\t{row_stamp}\n")
PY
}

project_icon() {
    get_tsv_value "$ICONS_FILE" "$1"
}

get_screen_name() {
    local project="$1"
    local screen="$2"
    [ -f "$SCREEN_NAMES_FILE" ] || return 1
    awk -F'\t' -v project="$project" -v screen="$screen" '$1 == project && $2 == screen { print $3; exit }' "$SCREEN_NAMES_FILE"
}

set_screen_name() {
    local project="$1"
    local screen="$2"
    local name="$3"
    local tmp

    tmp=$(mktemp)
    [ -f "$SCREEN_NAMES_FILE" ] && awk -F'\t' -v project="$project" -v screen="$screen" '!( $1 == project && $2 == screen ) { print }' "$SCREEN_NAMES_FILE" > "$tmp"
    printf '%s\t%s\t%s\n' "$project" "$screen" "$name" >> "$tmp"
    mv "$tmp" "$SCREEN_NAMES_FILE"
}

delete_screen_name() {
    local project="$1"
    local screen="$2"
    local tmp

    tmp=$(mktemp)
    [ -f "$SCREEN_NAMES_FILE" ] && awk -F'\t' -v project="$project" -v screen="$screen" '!( $1 == project && $2 == screen ) { print }' "$SCREEN_NAMES_FILE" > "$tmp"
    mv "$tmp" "$SCREEN_NAMES_FILE"
}

rename_project_screen_names() {
    local old_name="$1"
    local new_name="$2"
    local tmp

    tmp=$(mktemp)
    if [ -f "$SCREEN_NAMES_FILE" ]; then
        awk -F'\t' -v old_name="$old_name" -v new_name="$new_name" '
            $1 == old_name { $1 = new_name }
            { print }
        ' OFS='\t' "$SCREEN_NAMES_FILE" > "$tmp"
        mv "$tmp" "$SCREEN_NAMES_FILE"
    fi
}

current_screen_context() {
    local active_ws
    local current_name
    local start
    local screen

    active_ws=$(active_workspace_id) || return 1

    current_name=$(project_for_workspace "$active_ws")
    [ -z "$current_name" ] && return 1

    start=$(get_start "$current_name")
    [ -z "$start" ] && return 1

    screen=$((active_ws - start + 1))
    printf '%s\t%s\t%s\n' "$current_name" "$start" "$screen"
}

ensure_waybar_project_context() {
    local active_ws
    local active_project

    active_ws=$(active_workspace_id || true)
    active_project=""
    if [ -n "$active_ws" ]; then
        active_project=$(project_for_workspace "$active_ws" || true)
    fi

    if [ -n "$active_project" ]; then
        current="$active_project"
        set_current "$current"
    else
        sync_from_workspace
        current=$(get_current)
    fi

    if [ -z "$current" ]; then
        if [ -n "$active_project" ]; then
            current="$active_project"
            debug_log "ensure_waybar_project_context" "recover_from_active_project -> $current active_ws=$active_ws"
            set_current "$current"
        elif [ -s "$PROJECTS_FILE" ]; then
            current=$(head -1 "$PROJECTS_FILE" | cut -f1)
            debug_log "ensure_waybar_project_context" "fallback_empty_current -> $current active_ws=$(active_workspace_id || printf '?')"
            set_current "$current"
        else
            return 1
        fi
    fi

    start=$(get_start "$current")
    if [ -z "$start" ]; then
        if [ -n "$active_project" ]; then
            current="$active_project"
            start=$(get_start "$current")
            debug_log "ensure_waybar_project_context" "recover_missing_start_from_active_project -> $current active_ws=$active_ws"
            [ -n "$start" ] && set_current "$current"
        elif [ -s "$PROJECTS_FILE" ]; then
            current=$(head -1 "$PROJECTS_FILE" | cut -f1)
            debug_log "ensure_waybar_project_context" "fallback_missing_start -> $current active_ws=$(active_workspace_id || printf '?')"
            set_current "$current"
            start=$(get_start "$current")
        else
            return 1
        fi
    fi

    active_ws=$(active_workspace_id || true)

    if [ -n "$start" ] && [ -n "$active_ws" ]; then
        screen=$((active_ws - start + 1))
    else
        screen=0
    fi

    occupied=$(hyprctl -j workspaces 2>/dev/null | jq -r \
        "[.[] | select(.id >= $start and .id < ($start + $BLOCK)) | .id - $start + 1] | .[]" 2>/dev/null)

    max_screen=$MIN_SCREENS
    for s in $(project_named_screens "$current"); do
        [ "$s" -gt "$max_screen" ] && max_screen="$s"
    done
    [ "$screen" -gt "$max_screen" ] && max_screen="$screen"

    return 0
}

project_named_screens() {
    local project="$1"
    [ -f "$SCREEN_NAMES_FILE" ] || return 0
    awk -F'\t' -v project="$project" '$1 == project { print $2 }' "$SCREEN_NAMES_FILE"
}

truncate_text() {
    local text="$1"
    local limit="$2"

    if [ "${#text}" -le "$limit" ]; then
        printf '%s' "$text"
    else
        printf '%s...' "${text:0:$((limit - 3))}"
    fi
}

emit_waybar_json() {
    local text="$1"
    local tooltip="$2"
    local class="$3"
    jq -cn --arg text "$text" --arg tooltip "$tooltip" --arg class "$class" '{text: $text, tooltip: $tooltip, class: $class}'
}

xml_escape() {
    printf '%s' "$1" | sed \
        -e 's/&/\&amp;/g' \
        -e 's/</\&lt;/g' \
        -e 's/>/\&gt;/g' \
        -e 's/"/\&quot;/g' \
        -e "s/'/\&apos;/g"
}

write_project_menu() {
    local tmp
    local current
    local index
    local name
    local label
    local label_escaped

    tmp=$(mktemp)
    current=$(get_current)
    index=1

    {
        printf '%s\n' '<?xml version="1.0" encoding="UTF-8"?>'
        printf '%s\n' '<interface>'
        printf '%s\n' '  <object class="GtkMenu" id="menu">'

        while IFS=$'\t' read -r name start; do
            [ -z "$name" ] && continue
            [ "$index" -gt 20 ] && break

            if [ "$name" = "$current" ]; then
                label="[$index] $name"
            else
                label="$index. $name"
            fi
            label_escaped=$(xml_escape "$label")

            printf '%s\n' '    <child>'
            printf '%s\n' "      <object class=\"GtkMenuItem\" id=\"project_${index}\">"
            printf '%s\n' "        <property name=\"label\">${label_escaped}</property>"
            printf '%s\n' '      </object>'
            printf '%s\n' '    </child>'

            index=$((index + 1))
        done < "$PROJECTS_FILE"

        if [ "$index" -gt 1 ]; then
            printf '%s\n' '    <child>'
            printf '%s\n' '      <object class="GtkSeparatorMenuItem" id="projects_separator" />'
            printf '%s\n' '    </child>'
        fi

        printf '%s\n' '    <child>'
        printf '%s\n' '      <object class="GtkMenuItem" id="new_project">'
        printf '%s\n' '        <property name="label">New Project...</property>'
        printf '%s\n' '      </object>'
        printf '%s\n' '    </child>'
        printf '%s\n' '  </object>'
        printf '%s\n' '</interface>'
    } > "$tmp"

    mv "$tmp" "$PROJECT_MENU_FILE"
}

focus_window_target() {
    local addr="$1"
    local ws="$2"
    local proj="$3"

    [ -n "$proj" ] && [ "$proj" != "untracked" ] && activate_project "$proj"
    [ -n "$ws" ] && hyprctl dispatch workspace "$ws" > /dev/null
    hyprctl dispatch focuswindow "address:${addr}" > /dev/null 2>&1
}

window_workspace() {
    local addr="$1"
    hyprctl -j clients 2>/dev/null | jq -r --arg addr "$addr" '.[] | select(.address == $addr) | .workspace.id' 2>/dev/null | head -n1
}

active_window_address() {
    hyprctl -j activewindow 2>/dev/null | jq -r '.address // empty' 2>/dev/null
}

monitor_for_workspace() {
    local ws="$1"
    hyprctl -j monitors 2>/dev/null | jq -r --argjson ws "$ws" '.[] | select(.activeWorkspace.id == $ws) | .name' 2>/dev/null | head -n1
}

focus_workspace_target() {
    local ws="$1"
    local addr="$2"
    local mon

    mon=$(monitor_for_workspace "$ws")

    if [ -n "$mon" ] && [ "$mon" != "null" ]; then
        hyprctl dispatch focusmonitor "$mon" > /dev/null 2>&1
    else
        hyprctl dispatch workspace "$ws" > /dev/null 2>&1
    fi

    [ -n "$addr" ] && hyprctl dispatch focuswindow "address:${addr}" > /dev/null 2>&1
}

current_project_name() {
    local active_ws
    active_ws=$(active_workspace_id) || return 1
    project_for_workspace "$active_ws"
}

project_name_by_offset() {
    local current="$1"
    local offset="$2"
    local names
    local count
    local i
    local target_i

    mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
    count=${#names[@]}
    [ "$count" -gt 0 ] || return 1

    for i in "${!names[@]}"; do
        if [ "${names[$i]}" = "$current" ]; then
            target_i=$(( (i + offset + count) % count ))
            printf '%s\n' "${names[$target_i]}"
            return 0
        fi
    done

    return 1
}

project_for_workspace() {
    local workspace_id="$1"
    while IFS=$'\t' read -r name start; do
        local end=$((start + BLOCK - 1))
        if [ "$workspace_id" -ge "$start" ] && [ "$workspace_id" -le "$end" ]; then
            printf '%s\n' "$name"
            return 0
        fi
    done < "$PROJECTS_FILE"
    return 1
}

next_start() {
    local max=0
    while IFS=$'\t' read -r name start; do
        [ "$start" -gt "$max" ] && max="$start"
    done < "$PROJECTS_FILE"
    if [ "$max" -eq 0 ]; then
        echo 1
    else
        echo $((max + BLOCK))
    fi
}

signal_waybar() {
    write_project_menu
    pkill -RTMIN+11 waybar 2>/dev/null
}

normalize_id() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]'
}

build_apps_cache() {
    local tmp
    local desktop

    tmp=$(mktemp)

    for desktop in /usr/share/applications/*.desktop "$HOME"/.local/share/applications/*.desktop; do
        [ -f "$desktop" ] || continue
        awk -F= -v desktop="$desktop" '
            /^\[Desktop Entry\]$/ { in_entry=1; next }
            /^\[/ && $0 != "[Desktop Entry]" { in_entry=0 }
            !in_entry { next }
            /^Name=/ && name == "" { name=substr($0, 6) }
            /^StartupWMClass=/ && startup == "" { startup=substr($0, 16) }
            /^Icon=/ && icon == "" { icon=substr($0, 6) }
            /^NoDisplay=/ && nodisplay == "" { nodisplay=tolower(substr($0, 11)) }
            /^Hidden=/ && hidden == "" { hidden=tolower(substr($0, 8)) }
            END {
                if (name != "" && nodisplay != "true" && hidden != "true") {
                    printf "%s\t%s\t%s\t%s\n", name, startup, icon, desktop
                }
            }
        ' "$desktop" >> "$tmp"
    done

    sort -u "$tmp" -o "$tmp"
    mv "$tmp" "$APPS_CACHE"
}

ensure_apps_cache() {
    if [ ! -f "$APPS_CACHE" ]; then
        build_apps_cache
        return
    fi

    if ! awk -F'\t' 'NR == 1 { exit(NF < 4 ? 0 : 1) }' "$APPS_CACHE"; then
        :
    else
        build_apps_cache
        return
    fi

    if find /usr/share/applications "$HOME"/.local/share/applications -maxdepth 1 -type f -name '*.desktop' -newer "$APPS_CACHE" -print -quit 2>/dev/null | grep -q .; then
        build_apps_cache
    fi
}

menu_payload_decode() {
    printf '%s' "$1" | base64 -d
}

menu_build_json() {
    ensure_apps_cache
    "$HOME/.local/bin/hypr-spotlight-menu-json"
}

menu_open_value() {
    local raw="$1"
    local kind="${raw%%:*}"
    local payload="${raw#*:}"
    local decoded
    local addr
    local ws
    local proj
    local desktop_file
    local action
    local verb
    local target
    local screen_num
    local start

    case "$kind" in
        window)
            decoded=$(menu_payload_decode "$payload")
            IFS=$'\t' read -r addr ws proj <<< "$decoded"
            [ -z "$addr" ] && exit 1
            focus_window_target "$addr" "$ws" "$proj"
            increment_usage "$raw"
            signal_waybar
            ;;
        app)
            desktop_file=$(menu_payload_decode "$payload")
            [ -z "$desktop_file" ] && exit 1
            if [ -f "$desktop_file" ]; then
                exec_line=$(grep -m1 "^Exec=" "$desktop_file" | cut -d= -f2- | sed 's/ %[fFuU]//g')
                uwsm app -- $exec_line &disown 2>/dev/null
                increment_usage "$raw"
            fi
            ;;
        project)
            proj=$(menu_payload_decode "$payload")
            [ -z "$proj" ] && exit 1
            activate_project "$proj"
            increment_usage "$raw"
            ;;
        window-action)
            decoded=$(menu_payload_decode "$payload")
            IFS=$'\t' read -r verb addr ws proj target <<< "$decoded"
            [ -z "$verb" ] || [ -z "$addr" ] && exit 1

            case "$verb" in
                close)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch closewindow "address:${addr}" > /dev/null 2>&1
                    ;;
                float)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch togglefloating > /dev/null 2>&1
                    ;;
                fullscreen)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch fullscreen 0 > /dev/null 2>&1
                    ;;
                move-project)
                    [ -z "$target" ] && exit 1
                    start=$(get_start "$target")
                    [ -z "$start" ] && exit 1

                    if [ -n "$proj" ] && [ "$proj" != "untracked" ]; then
                        current_start=$(get_start "$proj")
                        if [ -n "$current_start" ]; then
                            screen_num=$((ws - current_start + 1))
                        fi
                    fi

                    if [ -z "${screen_num:-}" ] || [ "$screen_num" -lt 1 ]; then
                        screen_num=1
                    fi

                    target_ws=$((start + screen_num - 1))
                    hyprctl dispatch movetoworkspacesilent "$target_ws,address:${addr}" > /dev/null 2>&1 || true
                    moved_ws=$(window_workspace "$addr")
                    if [ "$moved_ws" != "$target_ws" ]; then
                        focus_window_target "$addr" "$ws" "$proj"
                        hyprctl dispatch movetoworkspacesilent "$target_ws" > /dev/null 2>&1
                    fi
                    activate_project "$target"
                    hyprctl dispatch focuswindow "address:${addr}" > /dev/null 2>&1
                    ;;
            esac
            increment_usage "$raw"
            signal_waybar
            ;;
        action)
            action="$payload"
            case "$action" in
                create)       "$0" create ;;
                close-project) "$0" close ;;
                name)         "$0" name ;;
                name-window)  "$0" name-window ;;
                icon)         "$0" icon ;;
                clear-icon)   "$0" clear-icon ;;
                focus-mode)   hypr-screens solo ;;
                all-screens)  hypr-screens all ;;
                screen-menu)  hypr-screens menu ;;
            esac
            increment_usage "$raw"
            ;;
    esac
}

# Switch all monitors to a project's screens (monitor 1→screen 1, monitor 2→screen 2, etc.)
activate_project() {
    local name="$1"
    local start
    start=$(get_start "$name")
    [ -z "$start" ] && return 1

    # Preserve each monitor's current screen number, regardless of which
    # project block it currently belongs to.
    local screen_map=()
    mapfile -t screen_map < <(
        hyprctl -j monitors 2>/dev/null | jq -r --argjson block "$BLOCK" '
            sort_by(.id)
            | .[]
            | . as $monitor
            | ($monitor.activeWorkspace.id // 0) as $ws
            | if $ws >= 1
              then "\($monitor.name)\t\((($ws - 1) % $block) + 1)"
              else empty
              end
        '
    )
    if [ "${#screen_map[@]}" -eq 0 ]; then
        local fallback_monitors
        mapfile -t fallback_monitors < <(hyprctl -j monitors 2>/dev/null | jq -r 'sort_by(.id) | .[].name')
        local i=1
        local mon
        for mon in "${fallback_monitors[@]}"; do
            screen_map+=("${mon}"$'\t'"${i}")
            i=$((i + 1))
        done
    fi
    local mon_count=${#screen_map[@]}

    if [ "$mon_count" -le 1 ]; then
        # Single monitor: just switch workspace
        hyprctl dispatch workspace "$start" > /dev/null
    else
        # Multi-monitor: switch each monitor explicitly. `hyprctl --batch`
        # can leave non-focused monitors unchanged for workspace dispatches.
        local focused
        focused=$(hyprctl -j monitors 2>/dev/null | jq -r '.[] | select(.focused) | .name')

        local entry
        for entry in "${screen_map[@]}"; do
            local mon="${entry%%$'\t'*}"
            local screen="${entry#*$'\t'}"
            [ "$screen" -gt "$BLOCK" ] && continue
            local ws=$((start + screen - 1))
            hyprctl dispatch focusmonitor "$mon" > /dev/null 2>&1
            hyprctl dispatch workspace "$ws" > /dev/null 2>&1
        done

        # Return focus to the originally focused monitor.
        [ -n "$focused" ] && hyprctl dispatch focusmonitor "$focused" > /dev/null 2>&1
    fi

    set_current "$name"
    signal_waybar
}

# Auto-detect current project from active workspace
sync_from_workspace() {
    local active_ws
    active_ws=$(active_workspace_id) || return

    while IFS=$'\t' read -r name start; do
        local end=$((start + BLOCK - 1))
        if [ "$active_ws" -ge "$start" ] && [ "$active_ws" -le "$end" ]; then
            set_current "$name"
            return
        fi
    done < "$PROJECTS_FILE"
}

# Auto-create a default project if none exist
ensure_project() {
    local current
    current=$(get_current)
    if [ -z "$current" ] || [ -z "$(get_start "$current")" ]; then
        if [ ! -s "$PROJECTS_FILE" ]; then
            printf '%s\t%s\n' "main" "1" >> "$PROJECTS_FILE"
            set_current "main"
        else
            set_current "$(head -1 "$PROJECTS_FILE" | cut -f1)"
        fi
    fi
}

case "$1" in
    create)
        name="${2:-$(walker -d -I -p "  New project:")}"
        name=$(echo "$name" | xargs)  # trim
        [ -z "$name" ] && exit 1

        # If exists, just switch to it
        existing_start=$(get_start "$name")
        if [ -n "$existing_start" ]; then
            activate_project "$name"
            exit 0
        fi

        start=$(next_start)
        printf '%s\t%s\n' "$name" "$start" >> "$PROJECTS_FILE"
        activate_project "$name"
        ;;

    switch)
        if [ -n "$2" ]; then
            name="$2"
        else
            name=$(cut -f1 "$PROJECTS_FILE" | walker -d -p "  Switch project:")
            name=$(echo "$name" | xargs)
        fi
        [ -z "$name" ] && exit 1

        start=$(get_start "$name")
        [ -z "$start" ] && exit 1

        activate_project "$name"
        ;;

    go)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        focus_workspace_target "$ws"
        signal_waybar
        ;;

    move)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        addr=$(active_window_address)
        hyprctl dispatch movetoworkspacesilent "$ws" > /dev/null
        focus_workspace_target "$ws" "$addr"
        signal_waybar
        ;;

    close)
        name="${2:-$(get_current)}"
        [ -z "$name" ] && exit 1

        tmp=$(mktemp)
        while IFS=$'\t' read -r n s; do
            [ "$n" != "$name" ] && printf '%s\t%s\n' "$n" "$s"
        done < "$PROJECTS_FILE" > "$tmp"
        mv "$tmp" "$PROJECTS_FILE"
        delete_tsv_key "$ICONS_FILE" "$name"

        if [ "$(get_current)" = "$name" ]; then
            first=$(head -1 "$PROJECTS_FILE" | cut -f1)
            if [ -n "$first" ]; then
                activate_project "$first"
            else
                clear_current
            fi
        fi
        signal_waybar
        ;;

    next)
        active_ws=$(active_workspace_id || true)
        current=$( [ -n "$active_ws" ] && project_for_workspace "$active_ws" || get_current )
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                next_i=$(( (i + 1) % count ))
                name="${names[$next_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    prev)
        active_ws=$(active_workspace_id || true)
        current=$( [ -n "$active_ws" ] && project_for_workspace "$active_ws" || get_current )
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                prev_i=$(( (i - 1 + count) % count ))
                name="${names[$prev_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    project-screen-next)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$screen" ] && exit 1

        target=$(project_name_by_offset "$current_name" 1) || exit 0
        target_start=$(get_start "$target")
        [ -z "$target_start" ] && exit 1

        target_ws=$((target_start + screen - 1))
        hyprctl dispatch workspace "$target_ws" > /dev/null 2>&1
        set_current "$target"
        signal_waybar
        ;;

    project-screen-prev)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$screen" ] && exit 1

        target=$(project_name_by_offset "$current_name" -1) || exit 0
        target_start=$(get_start "$target")
        [ -z "$target_start" ] && exit 1

        target_ws=$((target_start + screen - 1))
        hyprctl dispatch workspace "$target_ws" > /dev/null 2>&1
        set_current "$target"
        signal_waybar
        ;;

    screen-next)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$start" ] || [ -z "$screen" ] && exit 1

        target_screen=$(( (screen % BLOCK) + 1 ))
        target_ws=$((start + target_screen - 1))
        hyprctl dispatch workspace "$target_ws" > /dev/null 2>&1
        set_current "$current_name"
        signal_waybar
        ;;

    screen-prev)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$start" ] || [ -z "$screen" ] && exit 1

        target_screen=$(( (screen - 2 + BLOCK) % BLOCK + 1 ))
        target_ws=$((start + target_screen - 1))
        hyprctl dispatch workspace "$target_ws" > /dev/null 2>&1
        set_current "$current_name"
        signal_waybar
        ;;

    switch-index)
        index="$2"
        [ -z "$index" ] && exit 1
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        target="${names[$((index - 1))]}"
        [ -z "$target" ] && exit 0
        activate_project "$target"
        ;;

    list)
        cut -f1 "$PROJECTS_FILE"
        ;;

    current)
        get_current
        ;;

    name)
        active_ws=$(active_workspace_id) || exit 1

        current_name=$(project_for_workspace "$active_ws")
        [ -z "$current_name" ] && exit 1

        new_name="${2:-$(walker -d -I -p "  Rename project:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0
        [ "$new_name" = "$current_name" ] && exit 0

        if get_start "$new_name" >/dev/null; then
            exit 1
        fi

        tmp=$(mktemp)
        while IFS=$'\t' read -r name start; do
            if [ "$name" = "$current_name" ]; then
                printf '%s\t%s\n' "$new_name" "$start"
            else
                printf '%s\t%s\n' "$name" "$start"
            fi
        done < "$PROJECTS_FILE" > "$tmp"
        mv "$tmp" "$PROJECTS_FILE"

        if [ "$(get_current)" = "$current_name" ]; then
            set_current "$new_name"
        fi

        current_icon=$(project_icon "$current_name")
        if [ -n "$current_icon" ]; then
            delete_tsv_key "$ICONS_FILE" "$current_name"
            set_tsv_value "$ICONS_FILE" "$new_name" "$current_icon"
        fi

        rename_project_screen_names "$current_name" "$new_name"

        signal_waybar
        ;;

    name-screen)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$screen" ] && exit 1
        if [ -n "$2" ]; then
            case "$2" in
                ''|*[!0-9]*)
                    new_name="$2"
                    ;;
                *)
                    screen="$2"
                    new_name="$3"
                    ;;
            esac
        fi
        case "$screen" in
            ''|*[!0-9]*)
                exit 1
                ;;
        esac
        [ "$screen" -lt 1 ] || [ "$screen" -gt "$BLOCK" ] && exit 1

        current_screen_name=$(get_screen_name "$current_name" "$screen")
        new_name="${new_name:-$(walker -d -I -p "  Rename screen ${screen}:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0
        [ "$new_name" = "$current_screen_name" ] && exit 0

        set_screen_name "$current_name" "$screen" "$new_name"
        signal_waybar
        ;;

    clear-screen-name)
        IFS=$'\t' read -r current_name start screen <<< "$(current_screen_context)"
        [ -z "$current_name" ] || [ -z "$screen" ] && exit 1
        if [ -n "$2" ]; then
            screen="$2"
        fi
        case "$screen" in
            ''|*[!0-9]*)
                exit 1
                ;;
        esac
        [ "$screen" -lt 1 ] || [ "$screen" -gt "$BLOCK" ] && exit 1
        delete_screen_name "$current_name" "$screen"
        signal_waybar
        ;;

    name-window)
        addr=$(hyprctl -j activewindow 2>/dev/null | jq -r '.address' 2>/dev/null)
        [ -z "$addr" ] || [ "$addr" = "null" ] && exit 1

        current_name=""
        if [ -f "$NAMES_FILE" ]; then
            current_name=$(awk -F'\t' -v addr="$addr" '$1 == addr { print $2; exit }' "$NAMES_FILE")
        fi

        new_name="${2:-$(walker -d -I -p "  Rename window:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0
        [ "$new_name" = "$current_name" ] && exit 0

        tmp=$(mktemp)
        if [ -f "$NAMES_FILE" ]; then
            awk -F'\t' -v addr="$addr" '$1 != addr { print }' "$NAMES_FILE" > "$tmp"
        fi
        printf '%s\t%s\n' "$addr" "$new_name" >> "$tmp"
        mv "$tmp" "$NAMES_FILE"
        ;;

    icon)
        current_name="$(current_project_name)"
        [ -z "$current_name" ] && exit 1

        current_icon=$(project_icon "$current_name")
        new_icon="${2:-}"
        if [ -z "$new_icon" ]; then
            new_icon=$(walker -d -I -p "  Project icon:" 2>/dev/null)
        fi
        new_icon=$(echo "$new_icon" | xargs)
        [ -z "$new_icon" ] && exit 0
        [ "$new_icon" = "$current_icon" ] && exit 0

        set_tsv_value "$ICONS_FILE" "$current_name" "$new_icon"
        signal_waybar
        ;;

    clear-icon)
        current_name="${2:-$(current_project_name)}"
        [ -z "$current_name" ] && exit 1
        delete_tsv_key "$ICONS_FILE" "$current_name"
        signal_waybar
        ;;

    find)
        omarchy-launch-walker -m menus:hypr-spotlight
        ;;

    menu-json)
        menu_build_json
        ;;

    menu-open)
        [ -z "$2" ] && exit 1
        menu_open_value "$2"
        ;;

    waybar-screen)
        target_screen="$2"
        case "$target_screen" in
            ''|*[!0-9]*)
                exit 1
                ;;
        esac
        [ "$target_screen" -lt 1 ] || [ "$target_screen" -gt "$BLOCK" ] && exit 1

        if ! ensure_waybar_project_context; then
            emit_waybar_json "" "" "empty"
            exit 0
        fi

        if [ "$target_screen" -gt "$max_screen" ]; then
            emit_waybar_json "" "" "empty"
            exit 0
        fi

        screen_name=$(get_screen_name "$current" "$target_screen")
        monitor_name=$(monitor_for_workspace $((start + target_screen - 1)))

        if [ -n "$screen_name" ]; then
            compact_label=$(truncate_text "$screen_name" 10)
            full_label="$screen_name"
        else
            compact_label="Screen ${target_screen}"
            full_label="Screen ${target_screen}"
        fi

        if [ "$target_screen" -eq "$screen" ]; then
            state="active"
        elif echo "$occupied" | grep -qx "$target_screen"; then
            state="occupied"
        else
            state="idle"
        fi

        text="${target_screen}"
        if [ -n "$screen_name" ]; then
            text+=" ${compact_label}"
        fi

        tooltip_rows=()
        tooltip_rows+=("${current}")
        tooltip_rows+=("[${target_screen}] ${full_label}")
        if [ -n "$monitor_name" ] && [ "$monitor_name" != "null" ]; then
            tooltip_rows+=("Visible on ${monitor_name}")
        elif [ "$state" = "occupied" ]; then
            tooltip_rows+=("Occupied")
        else
            tooltip_rows+=("Empty")
        fi
        tooltip_rows+=("")
        tooltip_rows+=("Click: go to screen")
        tooltip_rows+=("Middle: move window here")
        tooltip_rows+=("Right-click: rename screen")
        tooltip_lines=$(printf '%s\n' "${tooltip_rows[@]}")
        tooltip_lines=${tooltip_lines%$'\n'}

        emit_waybar_json "$text" "$tooltip_lines" "$state"
        ;;

    waybar)
        if ! ensure_waybar_project_context; then
            write_project_menu
            emit_waybar_json "  new" "Click to create a project" "empty"
            exit 0
        fi

        write_project_menu
        count=$(wc -l < "$PROJECTS_FILE" | xargs)
        current_icon=$(project_icon "$current")
        icon_prefix=""
        if [ -n "$current_icon" ]; then
            icon_prefix="${current_icon} "
        fi
        text_label="$icon_prefix$current"

        tooltip_rows=()
        tooltip_rows+=("${current}  (${count} projects)")
        tooltip_rows+=("Screen ${screen} of ${max_screen}")
        for i in $(seq 1 $max_screen); do
            screen_name=$(get_screen_name "$current" "$i")
            monitor_name=$(monitor_for_workspace $((start + i - 1)))

            if [ -n "$screen_name" ]; then
                label="$screen_name"
            else
                label="Screen ${i}"
            fi

            suffix=""
            if [ -n "$monitor_name" ] && [ "$monitor_name" != "null" ]; then
                suffix=" on ${monitor_name}"
            elif echo "$occupied" | grep -qx "$i"; then
                suffix=" occupied"
            fi

            if [ "$i" -eq "$screen" ]; then
                tooltip_rows+=("> [${i}] ${label}${suffix}")
            else
                tooltip_rows+=("  [${i}] ${label}${suffix}")
            fi
        done
        tooltip_rows+=("")
        tooltip_rows+=("Click: open project list | Right-click: new project | Middle: name current screen")
        tooltip_rows+=("Scroll: cycle projects")
        tooltip_lines=$(printf '%s\n' "${tooltip_rows[@]}")
        tooltip_lines=${tooltip_lines%$'\n'}

        emit_waybar_json "$text_label" "$tooltip_lines" "active"
        ;;

    *)
        echo "Usage: hypr-spotlight {create|switch|go|move|close|next|prev|name|name-screen|clear-screen-name|name-window|icon|clear-icon|find|list|current|waybar|menu-json|menu-open} [args]"
        exit 1
        ;;
esac
