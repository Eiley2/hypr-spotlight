#!/bin/bash

MIN_SCREENS=3
BLOCK=10
STATE_DIR="$HOME/.cache/hypr-spotlight"
PROJECTS_FILE="$STATE_DIR/projects"
CURRENT_FILE="$STATE_DIR/current"
NAMES_FILE="$STATE_DIR/window-names"
ICONS_FILE="$STATE_DIR/project-icons"
USAGE_FILE="$STATE_DIR/usage.tsv"
APPS_CACHE="$STATE_DIR/apps-cache.tsv"

mkdir -p "$STATE_DIR"
touch "$PROJECTS_FILE" "$NAMES_FILE" "$ICONS_FILE" "$USAGE_FILE"

get_current() {
    cat "$CURRENT_FILE" 2>/dev/null
}

get_start() {
    local name="$1"
    while IFS=$'\t' read -r n s; do
        [ "$n" = "$name" ] && echo "$s" && return
    done < "$PROJECTS_FILE"
}

get_tsv_value() {
    local file="$1"
    local key="$2"
    [ -f "$file" ] || return 1
    awk -F'\t' -v key="$key" '$1 == key { print $2; exit }' "$file"
}

set_tsv_value() {
    local file="$1"
    local key="$2"
    local value="$3"
    local tmp

    tmp=$(mktemp)
    [ -f "$file" ] && awk -F'\t' -v key="$key" '$1 != key { print }' "$file" > "$tmp"
    printf '%s\t%s\n' "$key" "$value" >> "$tmp"
    mv "$tmp" "$file"
}

delete_tsv_key() {
    local file="$1"
    local key="$2"
    local tmp

    tmp=$(mktemp)
    [ -f "$file" ] && awk -F'\t' -v key="$key" '$1 != key { print }' "$file" > "$tmp"
    mv "$tmp" "$file"
}

increment_usage() {
    local key="$1"
    python3 - "$USAGE_FILE" "$key" <<'PY'
from pathlib import Path
import sys
import time

path = Path(sys.argv[1])
key = sys.argv[2]
rows = {}

if path.exists():
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        rows[parts[0]] = [int(parts[1]), int(parts[2])]

count, _stamp = rows.get(key, [0, 0])
rows[key] = [count + 1, int(time.time())]

with path.open("w") as handle:
    for row_key, (row_count, row_stamp) in rows.items():
        handle.write(f"{row_key}\t{row_count}\t{row_stamp}\n")
PY
}

project_icon() {
    get_tsv_value "$ICONS_FILE" "$1"
}

focus_window_target() {
    local addr="$1"
    local ws="$2"
    local proj="$3"

    [ -n "$proj" ] && [ "$proj" != "untracked" ] && activate_project "$proj"
    [ -n "$ws" ] && hyprctl dispatch workspace "$ws" > /dev/null
    hyprctl dispatch focuswindow "address:${addr}" > /dev/null 2>&1
}

project_for_workspace() {
    local workspace_id="$1"
    while IFS=$'\t' read -r name start; do
        local end=$((start + BLOCK - 1))
        if [ "$workspace_id" -ge "$start" ] && [ "$workspace_id" -le "$end" ]; then
            printf '%s\n' "$name"
            return 0
        fi
    done < "$PROJECTS_FILE"
    return 1
}

next_start() {
    local max=0
    while IFS=$'\t' read -r name start; do
        [ "$start" -gt "$max" ] && max="$start"
    done < "$PROJECTS_FILE"
    if [ "$max" -eq 0 ]; then
        echo 1
    else
        echo $((max + BLOCK))
    fi
}

signal_waybar() {
    pkill -RTMIN+11 waybar 2>/dev/null
}

normalize_id() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]'
}

build_apps_cache() {
    local tmp
    local desktop

    tmp=$(mktemp)

    for desktop in /usr/share/applications/*.desktop "$HOME"/.local/share/applications/*.desktop; do
        [ -f "$desktop" ] || continue
        awk -F= -v desktop="$desktop" '
            /^\[Desktop Entry\]$/ { in_entry=1; next }
            /^\[/ && $0 != "[Desktop Entry]" { in_entry=0 }
            !in_entry { next }
            /^Name=/ && name == "" { name=substr($0, 6) }
            /^StartupWMClass=/ && startup == "" { startup=substr($0, 16) }
            /^Icon=/ && icon == "" { icon=substr($0, 6) }
            /^NoDisplay=/ && nodisplay == "" { nodisplay=tolower(substr($0, 11)) }
            /^Hidden=/ && hidden == "" { hidden=tolower(substr($0, 8)) }
            END {
                if (name != "" && nodisplay != "true" && hidden != "true") {
                    printf "%s\t%s\t%s\t%s\n", name, startup, icon, desktop
                }
            }
        ' "$desktop" >> "$tmp"
    done

    sort -u "$tmp" -o "$tmp"
    mv "$tmp" "$APPS_CACHE"
}

ensure_apps_cache() {
    if [ ! -f "$APPS_CACHE" ]; then
        build_apps_cache
        return
    fi

    if ! awk -F'\t' 'NR == 1 { exit(NF < 4 ? 0 : 1) }' "$APPS_CACHE"; then
        :
    else
        build_apps_cache
        return
    fi

    if find /usr/share/applications "$HOME"/.local/share/applications -maxdepth 1 -type f -name '*.desktop' -newer "$APPS_CACHE" -print -quit 2>/dev/null | grep -q .; then
        build_apps_cache
    fi
}

menu_payload_decode() {
    printf '%s' "$1" | base64 -d
}

menu_build_json() {
    ensure_apps_cache
    "$HOME/.local/bin/hypr-spotlight-menu-json"
}

menu_open_value() {
    local raw="$1"
    local kind="${raw%%:*}"
    local payload="${raw#*:}"
    local decoded
    local addr
    local ws
    local proj
    local desktop_file
    local action
    local verb
    local target
    local screen_num
    local start

    case "$kind" in
        window)
            decoded=$(menu_payload_decode "$payload")
            IFS=$'\t' read -r addr ws proj <<< "$decoded"
            [ -z "$addr" ] && exit 1
            focus_window_target "$addr" "$ws" "$proj"
            increment_usage "$raw"
            signal_waybar
            ;;
        app)
            desktop_file=$(menu_payload_decode "$payload")
            [ -z "$desktop_file" ] && exit 1
            if [ -f "$desktop_file" ]; then
                exec_line=$(grep -m1 "^Exec=" "$desktop_file" | cut -d= -f2- | sed 's/ %[fFuU]//g')
                uwsm app -- $exec_line &disown 2>/dev/null
                increment_usage "$raw"
            fi
            ;;
        project)
            proj=$(menu_payload_decode "$payload")
            [ -z "$proj" ] && exit 1
            activate_project "$proj"
            increment_usage "$raw"
            ;;
        window-action)
            decoded=$(menu_payload_decode "$payload")
            IFS=$'\t' read -r verb addr ws proj target <<< "$decoded"
            [ -z "$verb" ] || [ -z "$addr" ] && exit 1

            case "$verb" in
                close)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch closewindow "address:${addr}" > /dev/null 2>&1
                    ;;
                float)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch togglefloating > /dev/null 2>&1
                    ;;
                fullscreen)
                    focus_window_target "$addr" "$ws" "$proj"
                    hyprctl dispatch fullscreen 0 > /dev/null 2>&1
                    ;;
                move-project)
                    [ -z "$target" ] && exit 1
                    start=$(get_start "$target")
                    [ -z "$start" ] && exit 1

                    if [ -n "$proj" ] && [ "$proj" != "untracked" ]; then
                        current_start=$(get_start "$proj")
                        if [ -n "$current_start" ]; then
                            screen_num=$((ws - current_start + 1))
                        fi
                    fi

                    if [ -z "${screen_num:-}" ] || [ "$screen_num" -lt 1 ]; then
                        screen_num=1
                    fi

                    target_ws=$((start + screen_num - 1))
                    hyprctl dispatch movetoworkspacesilent "$target_ws,address:${addr}" > /dev/null 2>&1 || \
                        hyprctl dispatch movetoworkspacesilent "$target_ws" > /dev/null 2>&1
                    activate_project "$target"
                    hyprctl dispatch focuswindow "address:${addr}" > /dev/null 2>&1
                    ;;
            esac
            increment_usage "$raw"
            ;;
        action)
            action="$payload"
            case "$action" in
                create)       "$0" create ;;
                name)         "$0" name ;;
                name-window)  "$0" name-window ;;
                icon)         "$0" icon ;;
                clear-icon)   "$0" clear-icon ;;
                focus-mode)   hypr-screens solo ;;
                all-screens)  hypr-screens all ;;
                screen-menu)  hypr-screens menu ;;
            esac
            increment_usage "$raw"
            ;;
    esac
}

# Switch all monitors to a project's screens (monitor 1→screen 1, monitor 2→screen 2, etc.)
activate_project() {
    local name="$1"
    local start
    start=$(get_start "$name")
    [ -z "$start" ] && return 1

    echo "$name" > "$CURRENT_FILE"

    # Get monitor names sorted by ID
    local monitors
    mapfile -t monitors < <(hyprctl -j monitors 2>/dev/null | jq -r 'sort_by(.id) | .[].name')
    local mon_count=${#monitors[@]}

    if [ "$mon_count" -le 1 ]; then
        # Single monitor: just switch workspace
        hyprctl dispatch workspace "$start" > /dev/null
    else
        # Multi-monitor: batch assign screen per monitor
        local batch=""
        local focused
        focused=$(hyprctl -j monitors 2>/dev/null | jq -r '.[] | select(.focused) | .name')

        for i in "${!monitors[@]}"; do
            local ws=$((start + i))
            local mon="${monitors[$i]}"
            [ "$i" -ge "$BLOCK" ] && break
            batch+="dispatch focusmonitor ${mon}; dispatch workspace ${ws}; "
        done

        # Return focus to the originally focused monitor
        batch+="dispatch focusmonitor ${focused}"
        hyprctl --batch "$batch" > /dev/null
    fi

    signal_waybar
}

# Auto-detect current project from active workspace
sync_from_workspace() {
    local active_ws
    active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq '.id' 2>/dev/null)
    [ -z "$active_ws" ] && return

    while IFS=$'\t' read -r name start; do
        local end=$((start + BLOCK - 1))
        if [ "$active_ws" -ge "$start" ] && [ "$active_ws" -le "$end" ]; then
            echo "$name" > "$CURRENT_FILE"
            return
        fi
    done < "$PROJECTS_FILE"
}

# Auto-create a default project if none exist
ensure_project() {
    local current
    current=$(get_current)
    if [ -z "$current" ] || [ -z "$(get_start "$current")" ]; then
        if [ ! -s "$PROJECTS_FILE" ]; then
            printf '%s\t%s\n' "main" "1" >> "$PROJECTS_FILE"
            echo "main" > "$CURRENT_FILE"
        else
            head -1 "$PROJECTS_FILE" | cut -f1 > "$CURRENT_FILE"
        fi
    fi
}

case "$1" in
    create)
        name="${2:-$(walker -d -I -p "  New project:")}"
        name=$(echo "$name" | xargs)  # trim
        [ -z "$name" ] && exit 1

        # If exists, just switch to it
        existing_start=$(get_start "$name")
        if [ -n "$existing_start" ]; then
            activate_project "$name"
            exit 0
        fi

        start=$(next_start)
        printf '%s\t%s\n' "$name" "$start" >> "$PROJECTS_FILE"
        activate_project "$name"
        ;;

    switch)
        if [ -n "$2" ]; then
            name="$2"
        else
            name=$(cut -f1 "$PROJECTS_FILE" | walker -d -p "  Switch project:")
            name=$(echo "$name" | xargs)
        fi
        [ -z "$name" ] && exit 1

        start=$(get_start "$name")
        [ -z "$start" ] && exit 1

        activate_project "$name"
        ;;

    go)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        hyprctl dispatch workspace "$ws" > /dev/null
        signal_waybar
        ;;

    move)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        hyprctl dispatch movetoworkspacesilent "$ws" > /dev/null
        signal_waybar
        ;;

    close)
        name="${2:-$(get_current)}"
        [ -z "$name" ] && exit 1

        tmp=$(mktemp)
        while IFS=$'\t' read -r n s; do
            [ "$n" != "$name" ] && printf '%s\t%s\n' "$n" "$s"
        done < "$PROJECTS_FILE" > "$tmp"
        mv "$tmp" "$PROJECTS_FILE"

        if [ "$(get_current)" = "$name" ]; then
            first=$(head -1 "$PROJECTS_FILE" | cut -f1)
            if [ -n "$first" ]; then
                activate_project "$first"
            else
                > "$CURRENT_FILE"
            fi
        fi
        signal_waybar
        ;;

    next)
        current=$(get_current)
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                next_i=$(( (i + 1) % count ))
                name="${names[$next_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    prev)
        current=$(get_current)
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                prev_i=$(( (i - 1 + count) % count ))
                name="${names[$prev_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    switch-index)
        index="$2"
        [ -z "$index" ] && exit 1
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        target="${names[$((index - 1))]}"
        [ -z "$target" ] && exit 0
        activate_project "$target"
        ;;

    list)
        cut -f1 "$PROJECTS_FILE"
        ;;

    current)
        get_current
        ;;

    name)
        active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq '.id' 2>/dev/null)
        [ -z "$active_ws" ] || [ "$active_ws" = "null" ] && exit 1

        current_name=$(project_for_workspace "$active_ws")
        [ -z "$current_name" ] && exit 1

        new_name="${2:-$(walker -d -I -p "  Rename project:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0
        [ "$new_name" = "$current_name" ] && exit 0

        if get_start "$new_name" >/dev/null; then
            exit 1
        fi

        tmp=$(mktemp)
        while IFS=$'\t' read -r name start; do
            if [ "$name" = "$current_name" ]; then
                printf '%s\t%s\n' "$new_name" "$start"
            else
                printf '%s\t%s\n' "$name" "$start"
            fi
        done < "$PROJECTS_FILE" > "$tmp"
        mv "$tmp" "$PROJECTS_FILE"

        if [ "$(get_current)" = "$current_name" ]; then
            printf '%s\n' "$new_name" > "$CURRENT_FILE"
        fi

        signal_waybar
        ;;

    name-window)
        addr=$(hyprctl -j activewindow 2>/dev/null | jq -r '.address' 2>/dev/null)
        [ -z "$addr" ] || [ "$addr" = "null" ] && exit 1

        current_name=""
        if [ -f "$NAMES_FILE" ]; then
            current_name=$(awk -F'\t' -v addr="$addr" '$1 == addr { print $2; exit }' "$NAMES_FILE")
        fi

        new_name="${2:-$(walker -d -I -p "  Rename window:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0
        [ "$new_name" = "$current_name" ] && exit 0

        tmp=$(mktemp)
        if [ -f "$NAMES_FILE" ]; then
            awk -F'\t' -v addr="$addr" '$1 != addr { print }' "$NAMES_FILE" > "$tmp"
        fi
        printf '%s\t%s\n' "$addr" "$new_name" >> "$tmp"
        mv "$tmp" "$NAMES_FILE"
        ;;

    find)
        omarchy-launch-walker -m menus:hypr-spotlight
        ;;

    menu-json)
        menu_build_json
        ;;

    menu-open)
        [ -z "$2" ] && exit 1
        menu_open_value "$2"
        ;;

    waybar)
        sync_from_workspace
        current=$(get_current)

        if [ -z "$current" ]; then
            printf '{"text": "  new", "tooltip": "Click to create a project", "class": "empty"}\n'
            exit 0
        fi

        start=$(get_start "$current")
        active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq '.id' 2>/dev/null)

        if [ -n "$start" ] && [ -n "$active_ws" ]; then
            screen=$((active_ws - start + 1))
        else
            screen=0
        fi

        # Dynamic dots: show at least MIN_SCREENS, expand if more are occupied
        occupied=$(hyprctl -j workspaces 2>/dev/null | jq -r \
            "[.[] | select(.id >= $start and .id < ($start + $BLOCK)) | .id - $start + 1] | .[]" 2>/dev/null)

        max_screen=$MIN_SCREENS
        for s in $occupied; do
            [ "$s" -gt "$max_screen" ] && max_screen="$s"
        done
        [ "$screen" -gt "$max_screen" ] && max_screen="$screen"

        dots=""
        for i in $(seq 1 $max_screen); do
            if [ "$i" -eq "$screen" ]; then
                dots+=" 󰮯"
            elif echo "$occupied" | grep -qx "$i"; then
                dots+=" 󰊠"
            else
                dots+=" 󰧟"
            fi
        done

        count=$(wc -l < "$PROJECTS_FILE" | xargs)
        current_esc=$(echo "$current" | sed 's/"/\\"/g')

        printf '{"text": "%s%s", "tooltip": "%s  (%s projects)\\nScreen %d of %d\\n\\nClick: switch | Right-click: new | Middle: close\\nScroll: cycle projects", "class": "active"}\n' \
            "$current_esc" "$dots" "$current_esc" "$count" "$screen" "$max_screen"
        ;;

    *)
        echo "Usage: hypr-spotlight {create|switch|go|move|close|next|prev|name|name-window|find|list|current|waybar|menu-json|menu-open} [args]"
        exit 1
        ;;
esac
